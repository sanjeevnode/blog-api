# ── App ──────────────────────────────────────────────
ENVIRONMENT=
DEBUG=
SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_HOURS=
REFRESH_TOKEN_EXPIRE_DAYS=

# ── Database (Connects to Postgres on Host Port 7211) ──
POSTGRES_SERVER=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ── Redis (Connects to Redis on Host Port 7213) ────────
REDIS_URL=
OTP_EXPIRE_SECONDS=

# ── S3 / RustFS (Connects to RustFS on Host Port 7214) ──
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_BASE_URL=

# ── Email / Mailpit (Connects to Mailpit on Host Port 7216) ─
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME
SMTP_PASSWORD
EMAIL_FROM=
EMAIL_FROM_NAME=

# ── Ports (docker-compose mapped host ports) ──────────
APP_PORT=
POSTGRES_HOST_PORT=
MAILPIT_UI_PORT=
REDIS_HOST_PORT=
RUSTFS_PORT=
RUSTFS_CONSOLE_PORT=
MAILPIT_SMTP_PORT=
PGADMIN_PORT=
